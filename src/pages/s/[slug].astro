---
import Base from "../../layouts/Base.astro";
import { skills, getSkill } from "../../data/skills";
import { getCategory } from "../../data/categories";
import { fetchReadme } from "../../lib/fetchReadme";

export function getStaticPaths() {
  return skills.map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const skill = getSkill(slug!)!;
const cat = getCategory(skill.category);
const isPlanned = skill.status === "planned";
const title = `${skill.name} — El Tianguis`;
const readme = await fetchReadme(skill);
const ogImage = `/og/${skill.slug}.png`;

const repoName = skill.repo ? skill.repo.replace("https://github.com/", "").split("/")[1] : "";
const skillPath = skill.installPath ?? skill.slug;
const cloneCmd = skill.repo ? `git clone ${skill.repo}` : "";
const copyCmd = skill.repo
  ? `mkdir -p ~/.claude/skills\ncp -r ${repoName}/${skillPath} ~/.claude/skills/${skill.slug}`
  : "";
---
<Base title={title} description={skill.tagline} ogImage={ogImage}>
  <article class="wrap pt-16 pb-20 max-w-4xl">
    <a href="/" class="text-xs text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)]">← Volver al tianguis</a>

    <div class="mt-6 flex flex-wrap gap-2">
      {cat && <a href={`/c/${cat.slug}`} class="pill no-underline">{cat.name}</a>}
      {skill.mxLocal && <span class="pill pill-mx">MX-Local</span>}
      {skill.verified && <span class="pill pill-verified">Verificado</span>}
      {isPlanned && <span class="pill">Próximamente</span>}
    </div>

    <h1 class="mt-4 font-display text-5xl sm:text-6xl text-[color:var(--color-ink)] leading-[0.95] tracking-tight">
      {skill.name}
    </h1>
    <p class="mt-4 text-xl text-[color:var(--color-ink-muted)] leading-relaxed max-w-2xl">{skill.tagline}</p>

    <div class="mt-6 flex items-center gap-4 text-sm text-[color:var(--color-ink-soft)]">
      <div>
        por
        {skill.authorUrl ? (
          <a href={skill.authorUrl} class="text-[color:var(--color-ink-muted)] hover:text-[color:var(--color-terracota)]">{skill.author}</a>
        ) : (
          <span class="text-[color:var(--color-ink-muted)]">{skill.author}</span>
        )}
      </div>
      <span>·</span>
      <span class="tabular">agregado {skill.addedAt}</span>
    </div>

    {skill.repo ? (
      <>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={skill.repo} data-track="github_click" data-skill={skill.slug} class="btn btn-primary">
            Ver en GitHub ↗
          </a>
          <a href="#instalar" class="btn btn-secondary">Cómo instalar</a>
        </div>

        <section id="instalar" class="mt-10 p-6 rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-canvas-warm)]">
          <div class="text-[10px] font-mono tracking-[0.18em] uppercase text-[color:var(--color-ink-soft)] mb-3">
            Instalación
          </div>
          <h2 class="font-display text-2xl text-[color:var(--color-ink)]">Cómo usar este puesto en tu Claude Code</h2>
          <ol class="mt-5 space-y-5">
            <li class="flex gap-4">
              <div class="font-display text-2xl text-[color:var(--color-terracota)] w-8 leading-none flex-shrink-0">1</div>
              <div class="flex-1 min-w-0">
                <div class="text-sm text-[color:var(--color-ink-muted)] mb-2">Clona el repo</div>
                <pre class="p-3 rounded-md bg-[color:var(--color-ink)] text-[color:var(--color-arena)] text-xs overflow-x-auto font-mono"><code>{cloneCmd}</code></pre>
              </div>
            </li>
            <li class="flex gap-4">
              <div class="font-display text-2xl text-[color:var(--color-terracota)] w-8 leading-none flex-shrink-0">2</div>
              <div class="flex-1 min-w-0">
                <div class="text-sm text-[color:var(--color-ink-muted)] mb-2">
                  Copia el skill a tu folder de Claude Code
                </div>
                <pre class="p-3 rounded-md bg-[color:var(--color-ink)] text-[color:var(--color-arena)] text-xs overflow-x-auto font-mono"><code>{copyCmd}</code></pre>
              </div>
            </li>
            <li class="flex gap-4">
              <div class="font-display text-2xl text-[color:var(--color-terracota)] w-8 leading-none flex-shrink-0">3</div>
              <div class="flex-1 min-w-0">
                <div class="text-sm text-[color:var(--color-ink-muted)] mb-2">
                  Reinicia Claude Code. Ya puedes invocarlo escribiendo cualquier trigger del skill.
                </div>
                {skill.paidUpgrade && (
                  <div class="text-xs text-[color:var(--color-ink-soft)] italic">
                    Nota: este puesto tiene versión preview pública. Para la base de datos completa o el servicio hosted, revisa el banner de versión completa arriba.
                  </div>
                )}
              </div>
            </li>
          </ol>
        </section>
      </>
    ) : isPlanned ? (
      <div class="mt-8 p-5 rounded-xl bg-[color:var(--color-canvas-warm)] border border-[color:var(--color-border)]">
        <div class="font-display text-lg text-[color:var(--color-ink)]">Este skill está en la cola.</div>
        <p class="mt-1 text-sm text-[color:var(--color-ink-muted)]">
          Si te interesa construirlo o usarlo, escríbenos. Buscamos colaboradores de la comunidad MX/Latam.
        </p>
      </div>
    ) : null}

    <hr class="my-12 border-[color:var(--color-border)]" />

    <h2 class="font-display text-2xl text-[color:var(--color-ink)]">Qué hace</h2>
    <p class="mt-3 text-[color:var(--color-ink-muted)] leading-relaxed">{skill.description}</p>

    {skill.paidUpgrade && (
      <aside class="mt-10 p-5 rounded-xl border border-[color:var(--color-terracota)] bg-[color:var(--color-canvas-warm)] flex flex-col sm:flex-row gap-4 sm:items-center sm:justify-between">
        <div class="flex-1">
          <div class="text-[10px] font-mono tracking-[0.18em] uppercase text-[color:var(--color-terracota)] mb-1.5">
            {skill.paidUpgrade.label}
          </div>
          <div class="text-sm text-[color:var(--color-ink-muted)] leading-relaxed">
            {skill.paidUpgrade.description}
          </div>
        </div>
        <a href={skill.paidUpgrade.url} data-skill={skill.slug} class="btn btn-primary whitespace-nowrap">
          Conseguir →
        </a>
      </aside>
    )}

    {readme && (
      <section class="mt-12">
        <div class="flex items-center justify-between mb-4">
          <div class="text-[10px] font-mono tracking-[0.18em] uppercase text-[color:var(--color-ink-soft)]">
            Documentación del skill
          </div>
          {skill.repo && skill.readmePath && (
            <a
              href={`${skill.repo}/blob/${skill.branch ?? "main"}/${skill.readmePath}`}
              class="text-xs text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-terracota)]"
            >
              Editar en GitHub ↗
            </a>
          )}
        </div>
        <div class="prose-tianguis" set:html={readme.html} />
      </section>
    )}

    {skill.tags.length > 0 && (
      <>
        <h2 class="font-display text-2xl text-[color:var(--color-ink)] mt-12">Tags</h2>
        <div class="mt-3 flex flex-wrap gap-2">
          {skill.tags.map((t) => (
            <span class="pill">{t}</span>
          ))}
        </div>
      </>
    )}
  </article>
</Base>
