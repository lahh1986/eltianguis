---
import Base from "../../layouts/Base.astro";
import SkillCard from "../../components/SkillCard.astro";
import { categories, getCategory } from "../../data/categories";
import { skillsByCategory } from "../../data/skills";

export function getStaticPaths() {
  return categories.map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const cat = getCategory(slug!)!;
const items = skillsByCategory(slug!);
const title = `${cat.name} — El Tianguis`;
const description = cat.description;
---
<Base title={title} description={description}>
  <section class="wrap pt-16 pb-10 border-b border-[color:var(--color-border)]">
    <div class="flex items-center gap-2 mb-4">
      <a href="/" class="text-xs text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)]">← Volver al tianguis</a>
    </div>
    <div class="flex items-start justify-between gap-6 flex-wrap">
      <div class="max-w-2xl">
        <div class="text-[10px] font-mono tracking-[0.18em] uppercase text-[color:var(--color-terracota)] mb-2">
          Categoría {cat.featured && "· destacada"}
        </div>
        <h1 class="font-display text-5xl text-[color:var(--color-ink)] leading-tight">{cat.name}</h1>
        <p class="mt-3 text-lg text-[color:var(--color-ink-muted)] leading-relaxed">{cat.description}</p>
      </div>
      <div class="text-right">
        <div class="editorial-number text-6xl text-[color:var(--color-ink)]">{items.length}</div>
        <div class="text-xs text-[color:var(--color-ink-soft)] mt-1">skills</div>
      </div>
    </div>
  </section>

  <section class="wrap py-12">
    {items.length === 0 ? (
      <div class="text-center py-20">
        <div class="font-display text-2xl text-[color:var(--color-ink)]">Sin skills por aquí todavía.</div>
        <p class="mt-2 text-[color:var(--color-ink-muted)]">Sé el primero en publicar uno.</p>
        <a href="/publica" class="btn btn-primary mt-6 inline-flex">Publicar mi skill</a>
      </div>
    ) : (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {items.map((s) => <SkillCard skill={s} />)}
      </div>
    )}
  </section>
</Base>
