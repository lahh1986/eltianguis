---
interface Props {
  source?: string;
  variant?: "inline" | "section";
}

const { source = "home", variant = "section" } = Astro.props;
---
{variant === "section" ? (
  <section class="wrap pb-20">
    <div class="newsletter-card relative overflow-hidden rounded-2xl border border-[color:var(--color-border)] bg-[color:var(--color-canvas-warm)] p-8 sm:p-12">
      <div class="relative max-w-2xl">
        <div class="text-[10px] font-mono tracking-[0.18em] uppercase text-[color:var(--color-terracota)] mb-3">
          Boletín del tianguis
        </div>
        <h2 class="font-display text-3xl sm:text-4xl text-[color:var(--color-ink)] leading-tight">
          Cuando llegue algo bueno al tianguis, te avisamos.
        </h2>
        <p class="mt-3 text-[color:var(--color-ink-muted)] leading-relaxed">
          Un correo a la semana, máximo. Skills nuevos curados, lo que está moviendo a la comunidad MX/Latam de Claude Code, y avisos cuando publicamos algo propio. Cero spam, te sales cuando quieras.
        </p>

        <form data-newsletter-form data-source={source} class="mt-6 flex flex-col sm:flex-row gap-2 max-w-md">
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="tucorreo@ejemplo.mx"
            class="flex-1 px-4 py-3 rounded-lg border border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-[color:var(--color-ink)] placeholder:text-[color:var(--color-ink-soft)] focus:outline-none focus:border-[color:var(--color-terracota)]"
          />
          <button type="submit" class="btn btn-primary !rounded-lg whitespace-nowrap">
            Apuntarme
          </button>
        </form>

        <div data-newsletter-msg class="mt-3 text-sm min-h-[1.25rem] text-[color:var(--color-ink-muted)]"></div>
      </div>
    </div>
  </section>
) : (
  <form data-newsletter-form data-source={source} class="flex flex-col sm:flex-row gap-2 max-w-md">
    <input
      type="email"
      name="email"
      required
      autocomplete="email"
      placeholder="tucorreo@ejemplo.mx"
      class="flex-1 px-3 py-2 rounded-md border border-[color:var(--color-border-strong)] bg-[color:var(--color-surface)] text-sm"
    />
    <button type="submit" class="btn btn-primary !py-2 !px-4 !text-sm !rounded-md whitespace-nowrap">
      Apuntarme
    </button>
    <div data-newsletter-msg class="text-xs text-[color:var(--color-ink-muted)] sm:basis-full"></div>
  </form>
)}

<script>
  function bindForm(form: HTMLFormElement) {
    if (form.dataset.bound === "1") return;
    form.dataset.bound = "1";
    const msg = form.querySelector<HTMLElement>('[data-newsletter-msg]');
    const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const input = form.querySelector<HTMLInputElement>('input[name="email"]');
    if (!input || !btn) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = input.value.trim();
      if (!email) return;
      btn.disabled = true;
      btn.textContent = 'Enviando…';
      if (msg) msg.textContent = '';

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: form.dataset.source ?? 'home' }),
        });
        const data: { ok?: boolean; error?: string } = await res.json().catch(() => ({}));
        if (res.ok && data.ok) {
          form.reset();
          if (msg) msg.textContent = 'Listo. Te avisamos cuando llegue algo bueno.';
          if (msg) msg.style.color = 'var(--color-verified)';
          btn.textContent = '✓ Apuntado';
        } else if (data.error === 'invalid_email') {
          if (msg) msg.textContent = 'Ese correo no se ve bien. Revísalo.';
          btn.disabled = false;
          btn.textContent = 'Apuntarme';
        } else {
          if (msg) msg.textContent = 'Algo falló. Inténtalo en un minuto.';
          btn.disabled = false;
          btn.textContent = 'Apuntarme';
        }
      } catch {
        if (msg) msg.textContent = 'Sin conexión. Inténtalo de nuevo.';
        btn.disabled = false;
        btn.textContent = 'Apuntarme';
      }
    });
  }

  function init() {
    document.querySelectorAll<HTMLFormElement>('[data-newsletter-form]').forEach(bindForm);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
