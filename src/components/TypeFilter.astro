---
import { SKILL_TYPES, skills } from "../data/skills";

const counts = SKILL_TYPES.map((t) => ({
  ...t,
  count: skills.filter((s) => s.type === t.value).length,
}));
const total = skills.length;
---
<div class="type-filter wrap" data-type-filter>
  <div class="text-[10px] font-mono tracking-[0.18em] uppercase text-[color:var(--color-ink-soft)] mb-3">
    Filtrar por tipo
  </div>
  <div class="flex flex-wrap gap-2">
    <button
      type="button"
      class="filter-chip filter-chip-active"
      data-filter="all"
      aria-pressed="true"
    >
      Todos <span class="ml-1 opacity-60 tabular">{total}</span>
    </button>
    {counts.map((t) => (
      <button
        type="button"
        class="filter-chip"
        data-filter={t.value}
        aria-pressed="false"
        disabled={t.count === 0}
      >
        {t.label} <span class="ml-1 opacity-60 tabular">{t.count}</span>
      </button>
    ))}
    <button
      type="button"
      class="filter-chip filter-chip-mx"
      data-filter="mx-only"
      aria-pressed="false"
    >
      Solo MX/Latam
    </button>
  </div>
</div>

<style>
  .filter-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--color-border-strong);
    background: var(--color-surface);
    color: var(--color-ink-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }
  .filter-chip:hover:not(:disabled) {
    border-color: var(--color-ink);
    color: var(--color-ink);
  }
  .filter-chip:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
  .filter-chip-active {
    background: var(--color-ink);
    border-color: var(--color-ink);
    color: var(--color-arena);
  }
  .filter-chip-mx[aria-pressed="true"],
  .filter-chip-mx.filter-chip-active {
    background: var(--color-terracota);
    border-color: var(--color-terracota);
    color: var(--color-arena);
  }
</style>

<script>
  function setupFilter() {
    const root = document.querySelector('[data-type-filter]');
    if (!root) return;
    const chips = root.querySelectorAll<HTMLButtonElement>('.filter-chip');
    const cards = document.querySelectorAll<HTMLElement>('.skill-card-item');
    if (!chips.length || !cards.length) return;

    const state = { type: 'all' as string, mxOnly: false };

    function applyFilter() {
      cards.forEach((card) => {
        const type = card.dataset.type;
        const isMx = card.dataset.mxlocal === 'true';
        const typeMatch = state.type === 'all' || state.type === type;
        const mxMatch = !state.mxOnly || isMx;
        card.style.display = typeMatch && mxMatch ? '' : 'none';
      });
    }

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const filter = chip.dataset.filter as string;
        if (filter === 'mx-only') {
          state.mxOnly = !state.mxOnly;
          chip.setAttribute('aria-pressed', state.mxOnly ? 'true' : 'false');
          chip.classList.toggle('filter-chip-active', state.mxOnly);
        } else {
          state.type = filter;
          chips.forEach((c) => {
            if (c.dataset.filter !== 'mx-only') {
              const active = c.dataset.filter === filter;
              c.setAttribute('aria-pressed', active ? 'true' : 'false');
              c.classList.toggle('filter-chip-active', active);
            }
          });
        }
        applyFilter();
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupFilter);
  } else {
    setupFilter();
  }
</script>
